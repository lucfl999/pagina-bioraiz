# Variables de entorno para BIORAIZ
# Copiar este archivo a .env y rellenar con los valores correctos
# IMPORTANTE: Nunca subir .env a GitHub - está en .gitignore

# API Key de Brevo (Sendinblue) para envío de emails
# Obtener en: https://app.brevo.com/settings/keys/api
SENDINBLUE_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Puerto del servidor backend
PORT=3001

# URL del frontend para CORS
FRONTEND_URL=http://localhost:3000

# Ambiente
NODE_ENV=development
